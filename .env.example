# ----------------------------------------------------------------------------
# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA é commitado (ver .gitignore).
#
# MODELO DE ENTREGA (site feito para um cliente):
#   - DEV / homologação  -> chaves de TESTE. Nenhum dinheiro real circula.
#   - PRODUÇÃO            -> chaves LIVE da conta do CLIENTE. O dinheiro cai
#     direto na conta dele; você não precisa ser dono dessas contas.
# ----------------------------------------------------------------------------

# URL pública da aplicação (usada nas URLs de retorno do Mercado Pago).
# Em dev: http://localhost:3000  |  Em prod: https://seudominio.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mercado Pago (inscrições da corrida — cartão e Pix unificados) -------
# Painel MP > Seu negócio > Credenciais
# DEV: Access Token de TESTE  (começa com TEST-)
# PROD: Access Token de PRODUÇÃO (começa com APP_USR-)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (email) -------------------------------------------------------
# resend.com > API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Remetente. Para testar use onboarding@resend.dev.
# Em produção: endereço do domínio verificado no Resend.
EMAIL_FROM=onboarding@resend.dev

# Seu email — recebe a notificação a cada nova inscrição confirmada.
EMAIL_ADMIN=voce@seudominio.com.br

# --- Supabase (banco das inscrições) --------------------------------------
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service role key (SECRETA — só usada no servidor, nunca exposta ao browser).
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# --- Painel ADM (/esportivo/admin) ----------------------------------------
# Senha única de acesso ao painel de inscrições. Troque por algo forte.
ADMIN_PASSWORD=troque-esta-senha
